# Copy to .env and fill in. Used for sending verification and password-reset emails.
# Gmail: create an App Password at https://myaccount.google.com/apppasswords (requires 2-Step Verification).

MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password
MAIL_DEFAULT_SENDER=your-email@gmail.com
